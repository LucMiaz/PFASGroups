{
  "name": "pfas-benchmark-reviewer",
  "version": "1.0.0",
  "description": "Web application for reviewing and validating PFAS classification benchmarks",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server.js",
    "setup": "npm install && cd client && npm install",
    "import-data": "node scripts/import-benchmark-data.js",
    "test": "jest"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "pfas",
    "benchmark",
    "molecular",
    "classification",
    "review"
  ],
  "author": "Luc Miaz",
  "license": "CC-BY-NC-4.0"
}
