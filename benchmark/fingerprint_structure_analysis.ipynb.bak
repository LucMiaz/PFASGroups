   ],
   "source": [
    "from rdkit import Chem\n",
    "from rdkit.Chem import rdMolDescriptors\n",
    "import pandas as pd\n",
    "import os\n",
    "import re\n",
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "try:\n",
    "    NOTEBOOK_DIR = Path(__vsc_ipynb_file__).parent\n",
    "except NameError:\n",
    "    try:\n",
    "        NOTEBOOK_DIR = Path(__file__).parent\n",
    "    except NameError:\n",
    "        NOTEBOOK_DIR = Path.cwd()\n",
    "REPO_ROOT = NOTEBOOK_DIR.parent\n",
    "\n",
    "ARPHALE_XLSX = REPO_ROOT.parent / 'molecular_quantum_graph' / 'data' / 'arpHale_simplified.xlsx'\n",
    "SMILES_TABLE_S5 = NOTEBOOK_DIR / 'test_data' / 'Richard2023_SI_TableS5.csv'\n",
    "\n",
    "LOOKUP_DIR = NOTEBOOK_DIR / 'results' / 'lookups'\n",
    "LOOKUP_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "EC_LOOKUP_CSV = LOOKUP_DIR / 'ec_to_structure_lookup.csv'\n",
    "CAS_LOOKUP_CSV = LOOKUP_DIR / 'cas_to_structure_lookup.csv'\n",
    "ARPHALE_RESOLVED_CSV = LOOKUP_DIR / 'arphale_resolved_structures.csv'\n",
    "COMMON_MATCHES_CSV = LOOKUP_DIR / 'common_inchikey_formula_matches.csv'\n",
    "LOOKUP_META_JSON = LOOKUP_DIR / 'lookup_build_metadata.json'\n",
    "\n",
    "def _canon(s):\n",
    "    try:\n",
    "        m = Chem.MolFromSmiles(str(s))\n",
    "        return Chem.MolToSmiles(m, canonical=True) if m is not None else None\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "def _struct_from_smiles(s):\n",
    "    try:\n",
    "        mol = Chem.MolFromSmiles(str(s))\n",
    "        if mol is None:\n",
    "            return None\n",
    "        can = Chem.MolToSmiles(mol, canonical=True)\n",
    "        ik = Chem.MolToInchiKey(mol)\n",
    "        formula = rdMolDescriptors.CalcMolFormula(mol)\n",
    "        key = f\"{ik}|{formula}\" if ik and formula else None\n",
    "        return {\n",
    "            'canonical_smiles': can,\n",
    "            'inchikey': ik,\n",
    "            'formula': formula,\n",
    "            'match_key': key,\n",
    "        }\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "def _struct_from_parts(smiles=None, inchikey=None, formula=None):\n",
    "    if smiles is not None and str(smiles).strip():\n",
    "        s = _struct_from_smiles(smiles)\n",
    "        if s:\n",
    "            return s\n",
    "    ik = str(inchikey).strip() if inchikey is not None else ''\n",
    "    fm = str(formula).strip() if formula is not None else ''\n",
    "    if ik and fm:\n",
    "        return {\n",
    "            'canonical_smiles': None,\n",
    "            'inchikey': ik,\n",
    "            'formula': fm,\n",
    "            'match_key': f\"{ik}|{fm}\",\n",
    "        }\n",
    "    return None\n",
    "\n",
    "def _split_candidates(raw):\n",
    "    if pd.isna(raw):\n",
    "        return []\n",
    "    tokens = re.split(r'[;,|/]+', str(raw))\n",
    "    out = []\n",
    "    for tok in tokens:\n",
    "        t = tok.strip()\n",
    "        if not t:\n",
    "            continue\n",
    "        t = re.sub(r'^\\([^)]+\\)', '', t).strip()\n",
    "        if t:\n",
    "            out.append(t)\n",
    "    return list(dict.fromkeys(out))\n",
    "\n",
    "def _extract_ec_candidates(raw):\n",
    "    ecs = []\n",
    "    for tok in _split_candidates(raw):\n",
    "        m = re.search(r'\\b\\d{3}-\\d{3}-\\d\\b', tok)\n",
    "        if m:\n",
    "            ecs.append(m.group(0))\n",
    "    return list(dict.fromkeys(ecs))\n",
    "\n",
    "def _extract_cas_candidates(raw):\n",
    "    cas = []\n",
    "    for tok in _split_candidates(raw):\n",
    "        m = re.search(r'\\b\\d{2,7}-\\d{2}-\\d\\b', tok)\n",
    "        if m:\n",
    "            cas.append(m.group(0))\n",
    "    return list(dict.fromkeys(cas))\n",
    "\n",
    "def _read_lookup_csv(path):\n",
    "    if not path.exists():\n",
    "        return {}\n",
    "    try:\n",
    "        df = pd.read_csv(path, dtype=str)\n",
    "    except Exception:\n",
    "        return {}\n",
    "    required = {'key', 'canonical_smiles', 'inchikey', 'formula'}\n",
    "    if not required.issubset(set(df.columns)):\n",
    "        return {}\n",
    "    out = {}\n",
    "    for _, row in df.iterrows():\n",
    "        key = str(row['key']).strip() if pd.notna(row['key']) else ''\n",
    "        struct = _struct_from_parts(\n",
    "            smiles=row.get('canonical_smiles'),\n",
    "            inchikey=row.get('inchikey'),\n",
    "            formula=row.get('formula')\n",
    "        )\n",
    "        if key and struct and struct.get('match_key'):\n",
    "            out[key] = {\n",
    "                **struct,\n",
    "                'source': str(row.get('source', 'lookup_csv')).strip() if pd.notna(row.get('source')) else 'lookup_csv',\n",
    "            }\n",
    "    return out\n",
    "\n",
    "def _write_lookup_csv(path, mapping):\n",
    "    rows = []\n",
    "    for k, v in sorted(mapping.items()):\n",
    "        if not k or not isinstance(v, dict):\n",
    "            continue\n",
    "        if not v.get('inchikey') or not v.get('formula') or not v.get('match_key'):\n",
    "            continue\n",
    "        rows.append({\n",
    "            'key': k,\n",
    "            'canonical_smiles': v.get('canonical_smiles'),\n",
    "            'inchikey': v.get('inchikey'),\n",
    "            'formula': v.get('formula'),\n",
    "            'match_key': v.get('match_key'),\n",
    "            'source': v.get('source', ''),\n",
    "        })\n",
    "    pd.DataFrame(rows).to_csv(path, index=False)\n",
    "\n",
    "def _find_col(df, exact_names=None, contains_any=None):\n",
    "    exact_names = exact_names or []\n",
    "    contains_any = contains_any or []\n",
    "    cols = list(df.columns)\n",
    "    by_upper = {str(c).upper(): c for c in cols}\n",
    "    for name in exact_names:\n",
    "        if name.upper() in by_upper:\n",
    "            return by_upper[name.upper()]\n",
    "    for c in cols:\n",
    "        cu = str(c).upper()\n",
    "        if any(tag.upper() in cu for tag in contains_any):\n",
    "            return c\n",
    "    return None\n",
    "\n",
    "def _add_lookup_entry(lookup, key, struct, source):\n",
    "    if not key or not struct or not struct.get('match_key'):\n",
    "        return False\n",
    "    if key not in lookup:\n",
    "        lookup[key] = {**struct, 'source': source}\n",
    "        return True\n",
    "    return False\n",
    "\n",
    "def _first_existing(paths):\n",
    "    for p in paths:\n",
    "        if p is not None and Path(p).exists():\n",
    "            return Path(p)\n",
    "    return None\n",
    "\n",
    "def _build_local_identifier_lookups():\n",
    "    ec_to_struct = _read_lookup_csv(EC_LOOKUP_CSV)\n",
    "    cas_to_struct = _read_lookup_csv(CAS_LOOKUP_CSV)\n",
    "\n",
    "    s5 = pd.read_csv(SMILES_TABLE_S5, dtype=str)\n",
    "    s5.columns = [str(c).strip() for c in s5.columns]\n",
    "    smi_col = _find_col(s5, exact_names=['SMILES'])\n",
    "    cas_col = _find_col(s5, exact_names=['CASRN', 'CAS'], contains_any=['CAS'])\n",
    "    ec_col = _find_col(s5, exact_names=['EC', 'EINECS', 'ECN'], contains_any=['EC'])\n",
    "\n",
    "    if smi_col is None:\n",
    "        raise ValueError(f'No SMILES column found in {SMILES_TABLE_S5.name}')\n",
    "\n",
    "    for _, row in s5.iterrows():\n",
    "        if pd.isna(row[smi_col]):\n",
    "            continue\n",
    "        struct = _struct_from_smiles(row[smi_col])\n",
    "        if not struct:\n",
    "            continue\n",
    "\n",
    "        if cas_col is not None and pd.notna(row[cas_col]):\n",
    "            for cas in _extract_cas_candidates(row[cas_col]):\n",
    "                _add_lookup_entry(cas_to_struct, cas, struct, 'richard_s5')\n",
    "\n",
    "        if ec_col is not None and pd.notna(row[ec_col]):\n",
    "            for ec in _extract_ec_candidates(row[ec_col]):\n",
    "                _add_lookup_entry(ec_to_struct, ec, struct, 'richard_s5')\n",
    "\n",
    "    return ec_to_struct, cas_to_struct\n",
    "\n",
    "def _enrich_from_legacy_exports(ec_to_struct, cas_to_struct):\n",
    "    base_env = os.getenv('VPMPB_DATA_DIR')\n",
    "    base_candidates = [\n",
    "        Path(base_env) if base_env else None,\n",
    "        REPO_ROOT.parent / 'vPM-vPB gap' / 'data',\n",
    "        Path.home() / 'kDrive' / 'Documents' / 'WORK' / 'PhD' / 'vPM-vPB gap' / 'data',\n",
    "    ]\n",
    "    base_dir = _first_existing(base_candidates)\n",
    "    if base_dir is None:\n",
    "        print('Legacy exports not found; skipping offline legacy enrichment.')\n",
    "        return ec_to_struct, cas_to_struct, False\n",
    "\n",
    "    props_csv = _first_existing([base_dir / 'cas-only-reg-substances-with-all-props.csv'])\n",
    "    reg_csv = _first_existing([base_dir / 'reg-substances-export.csv'])\n",
    "    df_db_csv = _first_existing([base_dir / 'df_db.csv'])\n",
    "\n",
    "    added_ec = 0\n",
    "    added_cas = 0\n",
    "\n",
    "    if props_csv is not None:\n",
    "        try:\n",
    "            dfp = pd.read_csv(props_csv, dtype=str)\n",
    "            dfp.columns = [str(c).strip() for c in dfp.columns]\n",
    "            ec_col = _find_col(dfp, exact_names=['EC / List Number', 'EC', 'ECN'], contains_any=['EC'])\n",
    "            cas_col = _find_col(dfp, exact_names=['Cas Number', 'CASRN', 'CAS'], contains_any=['CAS'])\n",
    "            smi_col = _find_col(dfp, exact_names=['smiles', 'SMILES'], contains_any=['SMILE'])\n",
    "            ik_col = _find_col(dfp, exact_names=['inchikey', 'InChIKey'], contains_any=['INCHIKEY'])\n",
    "            fm_col = _find_col(dfp, exact_names=['formula', 'Formula'], contains_any=['FORMULA'])\n",
    "\n",
    "            for _, row in dfp.iterrows():\n",
    "                struct = _struct_from_parts(\n",
    "                    smiles=row[smi_col] if smi_col else None,\n",
    "                    inchikey=row[ik_col] if ik_col else None,\n",
    "                    formula=row[fm_col] if fm_col else None,\n",
    "                )\n",
    "                if not struct:\n",
    "                    continue\n",
    "                if ec_col is not None and pd.notna(row[ec_col]):\n",
    "                    for ec in _extract_ec_candidates(row[ec_col]):\n",
    "                        if ec not in ec_to_struct:\n",
    "                            _add_lookup_entry(ec_to_struct, ec, struct, 'legacy_props')\n",
    "                            added_ec += 1\n",
    "                if cas_col is not None and pd.notna(row[cas_col]):\n",
    "                    for cas in _extract_cas_candidates(row[cas_col]):\n",
    "                        if cas not in cas_to_struct:\n",
    "                            _add_lookup_entry(cas_to_struct, cas, struct, 'legacy_props')\n",
    "                            added_cas += 1\n",
    "            print(f'Legacy props enrichment OK: +{added_ec:,} EC and +{added_cas:,} CAS mappings')\n",
    "        except Exception as e:\n",
    "            print(f'Legacy props enrichment skipped ({type(e).__name__}: {e})')\n",
    "\n",
    "    if reg_csv is not None and df_db_csv is not None:\n",
    "        try:\n",
    "            dfd = pd.read_csv(df_db_csv, dtype=str)\n",
    "            dfd.columns = [str(c).strip() for c in dfd.columns]\n",
    "            dfd_cas_col = _find_col(dfd, exact_names=['CAS', 'CASRN'], contains_any=['CAS'])\n",
    "            dfd_smi_col = _find_col(dfd, exact_names=['smiles', 'SMILES'], contains_any=['SMILE'])\n",
    "            if dfd_cas_col and dfd_smi_col:\n",
    "                cas_struct = {}\n",
    "                for _, row in dfd.iterrows():\n",
    "                    if pd.isna(row[dfd_cas_col]) or pd.isna(row[dfd_smi_col]):\n",
    "                        continue\n",
    "                    struct = _struct_from_smiles(row[dfd_smi_col])\n",
    "                    if not struct:\n",
    "                        continue\n",
    "                    for cas in _extract_cas_candidates(row[dfd_cas_col]):\n",
    "                        cas_struct.setdefault(cas, struct)\n",
    "\n",
    "                dfr = pd.read_csv(reg_csv, dtype=str)\n",
    "                dfr.columns = [str(c).strip() for c in dfr.columns]\n",
    "                reg_ec_col = _find_col(dfr, exact_names=['EC / List Number', 'EC', 'ECN'], contains_any=['EC'])\n",
    "                reg_cas_col = _find_col(dfr, exact_names=['Cas Number', 'CASRN', 'CAS'], contains_any=['CAS'])\n",
    "\n",
    "                add2_ec = 0\n",
    "                add2_cas = 0\n",
    "                if reg_ec_col and reg_cas_col:\n",
    "                    for _, row in dfr.iterrows():\n",
    "                        if pd.isna(row[reg_cas_col]):\n",
    "                            continue\n",
    "                        struct = None\n",
    "                        for cas in _extract_cas_candidates(row[reg_cas_col]):\n",
    "                            if cas in cas_struct:\n",
    "                                struct = cas_struct[cas]\n",
    "                                if cas not in cas_to_struct:\n",
    "                                    _add_lookup_entry(cas_to_struct, cas, struct, 'legacy_dfdb_reg')\n",
    "                                    add2_cas += 1\n",
    "                                break\n",
    "                        if struct and pd.notna(row[reg_ec_col]):\n",
    "                            for ec in _extract_ec_candidates(row[reg_ec_col]):\n",
    "                                if ec not in ec_to_struct:\n",
    "                                    _add_lookup_entry(ec_to_struct, ec, struct, 'legacy_dfdb_reg')\n",
    "                                    add2_ec += 1\n",
    "                print(f'Legacy df_db+reg enrichment OK: +{add2_ec:,} EC and +{add2_cas:,} CAS mappings')\n",
    "        except Exception as e:\n",
    "            print(f'Legacy df_db+reg enrichment skipped ({type(e).__name__}: {e})')\n",
    "\n",
    "    return ec_to_struct, cas_to_struct, True\n",
    "\n",
    "def _enrich_from_clinventory(ec_to_struct, cas_to_struct):\n",
    "    try:\n",
    "        from sqlalchemy import create_engine\n",
    "    except Exception:\n",
    "        print('SQLAlchemy not available; skipping clinventory enrichment.')\n",
    "        return ec_to_struct, cas_to_struct, False\n",
    "\n",
    "    db_url = os.getenv('CLINVENTORY_DB_URL')\n",
    "    if not db_url:\n",
    "        db_name = os.getenv('CLINVENTORY_DB_NAME', 'clinventory')\n",
    "        # Prefer Unix-socket peer auth (no password); fall back to TCP\n",
    "        db_url = f'postgresql+psycopg2:///{db_name}?host=/var/run/postgresql'\n",
    "        _tcp_fallback = None\n",
    "        host = os.getenv('CLINVENTORY_DB_HOST')\n",
    "        if host:\n",
    "            port = os.getenv('CLINVENTORY_DB_PORT', '5432')\n",
    "            user = os.getenv('CLINVENTORY_DB_USER', os.getenv('USER', 'postgres'))\n",
    "            pwd = os.getenv('CLINVENTORY_DB_PASSWORD', '')\n",
    "            auth = f'{user}:{pwd}@' if pwd else f'{user}@'\n",
    "            _tcp_fallback = f'postgresql://{auth}{host}:{port}/{db_name}'\n",
    "\n",
    "    try:\n",
    "        engine = create_engine(db_url)\n",
    "        # Quick connectivity check\n",
    "        with engine.connect() as _c:\n",
    "            pass\n",
    "    except Exception as _e1:\n",
    "        if _tcp_fallback:\n",
    "            try:\n",
    "                engine = create_engine(_tcp_fallback)\n",
    "            except Exception as _e2:\n",
    "                print(f'clinventory enrichment skipped (connection failed: {_e1}; TCP fallback: {_e2})')\n",
    "                return ec_to_struct, cas_to_struct, False\n",
    "        else:\n",
    "            print(f'clinventory enrichment skipped ({type(_e1).__name__}: {_e1})')\n",
    "            return ec_to_struct, cas_to_struct, False\n",
    "\n",
    "    try:\n",
    "        added_ec = 0\n",
    "        added_cas = 0\n",
    "\n",
    "        # -- 1. comprehensive_analysis table ----------------------------------\n",
    "        # Pre-merged arpHale data with OPERA SMILES and InChIKeys.\n",
    "        # The 'ec' column may contain EC-format (NNN-NNN-N) or CAS-format\n",
    "        # identifiers depending on the original AH_CASRN entry.\n",
    "        _has_ca = False\n",
    "        try:\n",
    "            sql_ca = '''\n",
    "                SELECT ec, cas, inchikey, opera_smiles\n",
    "                FROM comprehensive_analysis\n",
    "                WHERE inchikey IS NOT NULL\n",
    "            '''\n",
    "            df_ca = pd.read_sql(sql_ca, engine)\n",
    "            for _, row in df_ca.iterrows():\n",
    "                struct = _struct_from_parts(\n",
    "                    smiles=row.get('opera_smiles'),\n",
    "                    inchikey=row.get('inchikey'),\n",
    "                )\n",
    "                if not struct or not struct.get('match_key'):\n",
    "                    continue\n",
    "                # ec column holds EC-format or CAS-format identifier\n",
    "                id_val = str(row['ec']).strip() if pd.notna(row.get('ec')) else ''\n",
    "                if id_val:\n",
    "                    for ec in _extract_ec_candidates(id_val):\n",
    "                        if _add_lookup_entry(ec_to_struct, ec, struct, 'comprehensive_analysis') is not False:\n",
    "                            added_ec += 1\n",
    "                    for cas in _extract_cas_candidates(id_val):\n",
    "                        if _add_lookup_entry(cas_to_struct, cas, struct, 'comprehensive_analysis') is not False:\n",
    "                            added_cas += 1\n",
    "                if pd.notna(row.get('cas')):\n",
    "                    for cas in _extract_cas_candidates(str(row['cas'])):\n",
    "                        if _add_lookup_entry(cas_to_struct, cas, struct, 'comprehensive_analysis') is not False:\n",
    "                            added_cas += 1\n",
    "            print(f'comprehensive_analysis enrichment: +{added_ec:,} EC/alt and +{added_cas:,} CAS mappings')\n",
    "            _has_ca = True\n",
    "        except Exception as _e_ca:\n",
    "            print(f'comprehensive_analysis table skipped ({type(_e_ca).__name__}: {_e_ca})')\n",
    "\n",
    "        # -- 2. substances table -----------------------------------------------\n",
    "        # Broader coverage for entries not in comprehensive_analysis.\n",
    "        # substances already has ECn, CAS, smiles, inchikey, formula directly.\n",
    "        try:\n",
    "            sql_sub = '''\n",
    "                SELECT \"ECn\" AS ec, \"CAS\" AS cas, smiles, inchikey, formula\n",
    "                FROM substances\n",
    "                WHERE (\"ECn\" IS NOT NULL OR \"CAS\" IS NOT NULL)\n",
    "                  AND (smiles IS NOT NULL OR inchikey IS NOT NULL)\n",
    "            '''\n",
    "            df_sub = pd.read_sql(sql_sub, engine)\n",
    "            add2_ec = 0\n",
    "            add2_cas = 0\n",
    "            for _, row in df_sub.iterrows():\n",
    "                struct = _struct_from_parts(\n",
    "                    smiles=row.get('smiles'),\n",
    "                    inchikey=row.get('inchikey'),\n",
    "                    formula=row.get('formula'),\n",
    "                )\n",
    "                if not struct or not struct.get('match_key'):\n",
    "                    continue\n",
    "                if pd.notna(row.get('ec')):\n",
    "                    for ec in _extract_ec_candidates(str(row['ec'])):\n",
    "                        if ec not in ec_to_struct:\n",
    "                            _add_lookup_entry(ec_to_struct, ec, struct, 'clinventory_substances')\n",
    "                            add2_ec += 1\n",
    "                if pd.notna(row.get('cas')):\n",
    "                    for cas in _extract_cas_candidates(str(row['cas'])):\n",
    "                        if cas not in cas_to_struct:\n",
    "                            _add_lookup_entry(cas_to_struct, cas, struct, 'clinventory_substances')\n",
    "                            add2_cas += 1\n",
    "            print(f'substances enrichment: +{add2_ec:,} EC and +{add2_cas:,} CAS mappings')\n",
    "            added_ec += add2_ec\n",
    "            added_cas += add2_cas\n",
    "        except Exception as _e_sub:\n",
    "            print(f'substances table skipped ({type(_e_sub).__name__}: {_e_sub})')\n",
    "\n",
    "        print(f'clinventory enrichment OK: total +{added_ec:,} EC and +{added_cas:,} CAS')\n",
    "        return ec_to_struct, cas_to_struct, True\n",
    "    except Exception as e:\n",
    "        print(f'clinventory enrichment skipped ({type(e).__name__}: {e})')\n",
    "        return ec_to_struct, cas_to_struct, False\n",
    "\n",
    "def _resolve_arphale_structures(df_arphale, ec_to_struct, cas_to_struct):\n",
    "    smi_col = _find_col(df_arphale, exact_names=['SMILES'], contains_any=['SMILE'])\n",
    "    id_col = _find_col(df_arphale, exact_names=['AH_CASRN', 'CASRN', 'CAS'], contains_any=['AH_CASRN', 'CAS'])\n",
    "\n",
    "    resolved = []\n",
    "    for _, row in df_arphale.iterrows():\n",
    "        struct = None\n",
    "        src = None\n",
    "        rid = None\n",
    "\n",
    "        if smi_col is not None and pd.notna(row[smi_col]):\n",
    "            struct = _struct_from_smiles(row[smi_col])\n",
    "            if struct:\n",
    "                src = f'arphale:{smi_col}'\n",
    "                rid = 'SMILES'\n",
    "\n",
    "        raw = row[id_col] if id_col is not None else None\n",
    "        if struct is None and raw is not None:\n",
    "            for ec in _extract_ec_candidates(raw):\n",
    "                if ec in ec_to_struct:\n",
    "                    struct = ec_to_struct[ec]\n",
    "                    src = 'lookup:EC'\n",
    "                    rid = ec\n",
    "                    break\n",
    "\n",
    "        if struct is None and raw is not None:\n",
    "            for cas in _extract_cas_candidates(raw):\n",
    "                if cas in cas_to_struct:\n",
    "                    struct = cas_to_struct[cas]\n",
    "                    src = 'lookup:CAS'\n",
    "                    rid = cas\n",
    "                    break\n",
    "\n",
    "        resolved.append({\n",
    "            'canonical_smiles': struct.get('canonical_smiles') if struct else None,\n",
    "            'inchikey': struct.get('inchikey') if struct else None,\n",
    "            'formula': struct.get('formula') if struct else None,\n",
    "            'match_key': struct.get('match_key') if struct else None,\n",
    "            'smiles_source': src,\n",
    "            'smiles_lookup_id': rid,\n",
    "        })\n",
    "\n",
    "    out = df_arphale.copy()\n",
    "    res_df = pd.DataFrame(resolved, index=out.index)\n",
    "    for c in res_df.columns:\n",
    "        out[c] = res_df[c]\n",
    "    return out\n",
    "\n",
    "# 1) Load ArpHale and resolve structures\n",
    "# Fast-path: load cached resolved structures if available (portable; no DB needed)\n",
    "_REQUIRED_RESOLVED_COLS = {'match_key', 'canonical_smiles', 'inchikey', 'formula'}\n",
    "_use_cache = (\n",
    "    ARPHALE_RESOLVED_CSV.exists()\n",
    "    and _REQUIRED_RESOLVED_COLS.issubset(set(pd.read_csv(ARPHALE_RESOLVED_CSV, nrows=0).columns))\n",
    ")\n",
    "if _use_cache:\n",
    "    # The resolved CSV already contains all arpHale columns plus structure cols,\n",
    "    # filtered to rows where match_key is not null.\n",
    "    df_arphale = pd.read_csv(ARPHALE_RESOLVED_CSV, dtype=str)\n",
    "    n_resolved = int(df_arphale['match_key'].notna().sum())\n",
    "    n_total_before = len(df_arphale)\n",
    "    print(f'Loaded cached ArpHale structures: {n_resolved}/{n_total_before} rows')\n",
    "    df_arphale = df_arphale[df_arphale['match_key'].notna()].copy()\n",
    "    _legacy_used = _db_used = '(cached)'\n",
    "else:\n",
    "    df_arphale = pd.read_excel(ARPHALE_XLSX)\n",
    "    ec_to_struct, cas_to_struct = _build_local_identifier_lookups()\n",
    "    ec_to_struct, cas_to_struct, _legacy_used = _enrich_from_legacy_exports(ec_to_struct, cas_to_struct)\n",
    "    ec_to_struct, cas_to_struct, _db_used = _enrich_from_clinventory(ec_to_struct, cas_to_struct)\n",
    "\n",
    "    # 2) Resolve ArpHale rows from SMILES/EC/CAS lookups (no PubChem)\n",
    "    df_arphale = _resolve_arphale_structures(df_arphale, ec_to_struct, cas_to_struct)\n",
    "    n_resolved = int(df_arphale['match_key'].notna().sum())\n",
    "    n_total_before = int(len(df_arphale))\n",
    "    print(f'Resolved ArpHale structures: {n_resolved}/{n_total_before} rows')\n",
    "    df_arphale = df_arphale[df_arphale['match_key'].notna()].copy()\n",
    "\n",
    "    # 3) Persist lookups for portability\n",
    "    _write_lookup_csv(EC_LOOKUP_CSV, ec_to_struct)\n",
    "    _write_lookup_csv(CAS_LOOKUP_CSV, cas_to_struct)\n",
    "    df_arphale.to_csv(ARPHALE_RESOLVED_CSV, index=False)\n",
    "\n",
    "LOOKUP_META_JSON.write_text(json.dumps({\n",
    "    'created_utc': pd.Timestamp.utcnow().isoformat(),\n",
    "    'used_legacy_exports': _legacy_used if isinstance(_legacy_used, str) else bool(_legacy_used),\n",
    "    'used_clinventory': _db_used if isinstance(_db_used, str) else bool(_db_used),\n",
    "    'n_ec_lookup': len(ec_to_struct) if 'ec_to_struct' in dir() else '(cached)',\n",
    "    'n_cas_lookup': len(cas_to_struct) if 'cas_to_struct' in dir() else '(cached)',\n",
    "    'n_arphale_rows_total': n_total_before,\n",
    "    'n_arphale_rows_resolved': n_resolved,\n",
    "    'match_strategy': 'inchikey+formula',\n",
    "    'files': {\n",
    "        'ec_lookup': str(EC_LOOKUP_CSV),\n",
    "        'cas_lookup': str(CAS_LOOKUP_CSV),\n",
    "        'arphale_resolved': str(ARPHALE_RESOLVED_CSV),\n",
    "        'common_matches': str(COMMON_MATCHES_CSV),\n",
    "    }\n",
    "}, indent=2), encoding='utf-8')\n",
    "print(f'Saved lookup files -> {LOOKUP_DIR}')\n",
    "\n",
    "# 4) Build Richard structure table from local S5\n",
    "df_s5 = pd.read_csv(SMILES_TABLE_S5, dtype=str)\n",
    "df_s5.columns = [str(c).strip() for c in df_s5.columns]\n",
    "dtx_col = _find_col(df_s5, exact_names=['DTXSID'], contains_any=['DTXSID'])\n",
    "smi_col = _find_col(df_s5, exact_names=['SMILES'], contains_any=['SMILES'])\n",
    "if dtx_col is None or smi_col is None:\n",
    "    raise ValueError('Could not find DTXSID/SMILES in Richard2023_SI_TableS5.csv')\n",
    "\n",
    "richard_rows = []\n",
    "richard_by_dtx = {}\n",
    "for _, row in df_s5.iterrows():\n",
    "    dtx = str(row[dtx_col]).strip() if pd.notna(row[dtx_col]) else ''\n",
    "    if not dtx or pd.isna(row[smi_col]):\n",
    "        continue\n",
    "    struct = _struct_from_smiles(row[smi_col])\n",
    "    if not struct or not struct.get('match_key'):\n",
    "        continue\n",
    "    richard_rows.append({\n",
    "        'DTXSID': dtx,\n",
    "        **struct,\n",
    "    })\n",
    "    if struct.get('canonical_smiles'):\n",
    "        richard_by_dtx[dtx] = struct['canonical_smiles']\n",
    "\n",
    "df_richard_struct = pd.DataFrame(richard_rows).drop_duplicates(subset=['DTXSID'])\n",
    "\n",
    "# 5) Compute overlap using InChIKey + formula\n",
    "arphale_key_set = set(df_arphale['match_key'].dropna())\n",
    "richard_key_set = set(df_richard_struct['match_key'].dropna())\n",
    "common_keys = sorted(arphale_key_set.intersection(richard_key_set))\n",
    "\n",
    "df_common_arphale = df_arphale[df_arphale['match_key'].isin(common_keys)].copy()\n",
    "df_common_richard = df_richard_struct[df_richard_struct['match_key'].isin(common_keys)].copy()\n",
    "df_common_pairs = (\n",
    "    df_common_arphale[['match_key', 'canonical_smiles', 'inchikey', 'formula', 'smiles_source', 'smiles_lookup_id']]\n",
    "    .merge(\n",
    "        df_common_richard[['match_key', 'DTXSID', 'canonical_smiles']],\n",
    "        on='match_key',\n",
    "        how='left',\n",
    "        suffixes=('_arphale', '_richard')\n",
    "    )\n",
    "    .drop_duplicates()\n",
    "    .sort_values('match_key')\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "df_common_pairs.to_csv(COMMON_MATCHES_CSV, index=False)\n",
    "\n",
    "# Keep compatibility with downstream cells\n",
    "common_smiles = sorted(df_common_arphale['canonical_smiles'].dropna().unique())\n",
    "\n",
    "print(f\"arpHale structures (InChIKey+formula): {df_arphale['match_key'].nunique():,}\")\n",
    "print(f\"Richard structures (InChIKey+formula): {df_richard_struct['match_key'].nunique():,}\")\n",
    "print(f\"Common structures:                  {len(common_keys):,}\")\n",
    "print(f\"Common canonical_smiles (compat):  {len(common_smiles):,}\")\n",
    "print(f\"Saved common matches -> {COMMON_MATCHES_CSV}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "#VSC-2271b842",
   "metadata": {
    "language": "python"
   },
   "outputs": [],
   "source": [
    "from sklearn.model_selection import KFold, GridSearchCV\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.ensemble import GradientBoostingRegressor\n",
    "\n",
    "if len(common_smiles) < 12:\n",
    "    print('Not enough common molecules for nested CV (need >= 12).')\n",
    "else:\n",
    "    dtx_for_smiles = {}\n",
    "    for d, s in richard_by_dtx.items():\n",
    "        dtx_for_smiles.setdefault(s, d)\n",
    "\n",
    "    df_common = df_arphale[df_arphale['canonical_smiles'].isin(common_smiles)].copy()\n",
    "    common_smi = list(df_common['canonical_smiles'])\n",
    "\n",
    "    cfg = srt[0] if 'srt' in globals() else {'kwargs': {'component_metrics': ['effective_graph_resistance']}, 'label': 'efg'}\n",
    "    fp = PFASFingerprint(common_smi, **cfg['kwargs'])\n",
    "    X_pfas = np.asarray(fp.fingerprints, dtype=float)\n",
    "    valid_mask = np.asarray(fp.valid_mask, dtype=bool) if hasattr(fp, 'valid_mask') else np.ones(len(common_smi), dtype=bool)\n",
    "\n",
    "    dtx_order = [dtx_for_smiles.get(s) for s in common_smi]\n",
    "    richard_idx = [ _valid_dtx.index(d) if (d in _valid_dtx) else None for d in dtx_order ]\n",
    "    richard_ok = np.array([i is not None for i in richard_idx], dtype=bool)\n",
    "\n",
    "    row_ok = valid_mask & richard_ok\n",
    "    X_pfas = X_pfas[row_ok]\n",
    "    rich_idx = np.array([i for i in richard_idx if i is not None], dtype=int)\n",
    "    X_rich = _txp_sub[rich_idx][valid_mask[richard_ok]] if row_ok.any() else None\n",
    "    y_df = df_common.loc[row_ok].copy()\n",
    "\n",
    "    # Explicit target columns: Abraham solvation descriptors + well-covered physicochemical endpoints.\n",
    "    # Use pd.to_numeric coercion because df_arphale is loaded with dtype=str from the cache CSV.\n",
    "    _PREFERRED_TARGETS = [\n",
    "        # Abraham solvation descriptors (QSAR-predicted)\n",
    "        'AH_E', 'AH_S', 'AH_A', 'AH_B', 'AH_V', 'AH_L',\n",
    "        # Well-covered physicochemical endpoints\n",
    "        'AH_P_t1_2QSAR_geom_avg',   # QSAR half-life geometric mean  (~220/222)\n",
    "        'AH_P_t1_2QSAR_geom_sd',    # QSAR half-life geometric SD     (~220/222)\n",
    "        'AH_log_Kow_Dow_exp_est',   # log Kow/Dow (exp or estimated)  (~220/222)\n",
    "        'AH_P_opera_t1_2',          # OPERA half-life                 (~200/222)\n",
    "        'AH_log_Kow_est_UFZ_LSER',  # log Kow UFZ-LSER estimate       (~195/222)\n",
    "    ]\n",
    "    target_cols = []\n",
    "    for c in _PREFERRED_TARGETS:\n",
    "        if c not in y_df.columns:\n",
    "            continue\n",
    "        v = pd.to_numeric(y_df[c], errors='coerce').dropna()\n",
    "        if len(v) >= 12 and v.nunique() >= 6:\n",
    "            target_cols.append(c)\n",
    "\n",
    "    print(f'Nested-CV candidates (numeric targets): {len(target_cols)}')\n",
    "\n",
    "    param_grid = {\n",
    "        'gbr__n_estimators': [100, 200],\n",
    "        'gbr__learning_rate': [0.05, 0.1],\n",
    "        'gbr__max_depth': [2, 3],\n",
    "        'gbr__min_samples_split': [2, 5],\n",
    "    }\n",
    "\n",
    "    rows = []\n",
    "    for t in target_cols:\n",
    "        yy = pd.to_numeric(y_df[t], errors='coerce').to_numpy(dtype=float)\n",
    "        ok = np.isfinite(yy)\n",
    "        if ok.sum() < 12:\n",
    "            continue\n",
    "        Xp = X_pfas[ok]\n",
    "        Xr = X_rich[ok] if X_rich is not None and len(X_rich) == len(yy) else None\n",
    "        y = yy[ok]\n",
    "\n",
    "        n_outer = max(3, min(5, len(y)//4))\n",
    "        n_inner = max(2, min(3, len(y)//6))\n",
    "        outer = KFold(n_splits=n_outer, shuffle=True, random_state=42)\n",
    "        inner = KFold(n_splits=n_inner, shuffle=True, random_state=42)\n",
    "\n",
    "        def _nested_score(X):\n",
    "            scores = []\n",
    "            for tr, te in outer.split(X):\n",
    "                pipe = Pipeline([('scaler', StandardScaler()), ('gbr', GradientBoostingRegressor(random_state=42))])\n",
    "                gs = GridSearchCV(pipe, param_grid=param_grid, cv=inner, scoring='r2', n_jobs=-1)\n",
    "                gs.fit(X[tr], y[tr])\n",
    "                scores.append(gs.score(X[te], y[te]))\n",
    "            return float(np.mean(scores)), float(np.std(scores))\n",
    "\n",
    "        p_mean, p_std = _nested_score(Xp)\n",
    "        r_mean, r_std = (np.nan, np.nan)\n",
    "        if Xr is not None and len(Xr) == len(y):\n",
    "            r_mean, r_std = _nested_score(Xr)\n",
    "\n",
    "        rows.append({\n",
    "            'target': t,\n",
    "            'n': int(len(y)),\n",
    "            'PFASGroups_r2_mean': p_mean,\n",
    "            'PFASGroups_r2_std': p_std,\n",
    "            'Richard_r2_mean': r_mean,\n",
    "            'Richard_r2_std': r_std,\n",
    "        })\n",
    "\n",
    "    if rows:\n",
    "        res = pd.DataFrame(rows)\n",
    "        display(res.style.background_gradient(subset=['PFASGroups_r2_mean', 'Richard_r2_mean'], cmap='RdYlGn', vmin=-1, vmax=1).format(precision=3))\n",
    "    else:\n",
    "        print('No target had enough valid data for nested CV.')\n"
   ]
  }
 ],
