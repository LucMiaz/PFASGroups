     "text": [
      "27/31 OK\n",
      "PFASGroups: 38 configs computed\n",
      "ideal_PFCA: 15 patterns, mean_T=0.547, min_T=0.167\n",
      "All labels: ['binary', 'binary+mol', 'c', 'c+mol', 'tc', 'tc+mol', 'egr', 'egr+mol', 'mdb', 'mdb+mol', 'egr+mdb', 'egr+mdb+mol', 'mrb', 'mrb+mol', 'mdc', 'mdc+mol', 'mdp', 'mdp+mol', 'mrc', 'mrc+mol', 'mrp', 'mrp+mol', 'egr+mdb+tc', 'egr+mdb+tc+mol', 'egr+mdb+mc', 'egr+mdb+mc+mol', 'egr+mdb+c', 'egr+mdb+c+mol', 'egr+mdb+b', 'egr+mdb+b+mol', 'egr+mrb+tc', 'egr+mrb+tc+mol', 'egr+mrb+mc', 'egr+mrb+mc+mol', 'egr+mrb+c', 'egr+mrb+c+mol', 'egr+mrb+b', 'egr+mrb+b+mol', 'ideal_PFCA']\n"
     ]
